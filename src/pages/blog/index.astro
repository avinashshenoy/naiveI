---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroBanner from "../../components/HeroBanner.astro";
import BlogPostCard from "../../components/BlogPostCard.astro";
import Sidebar from "../../components/Sidebar.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))];
---

<BaseLayout
  title="Blog"
  description="All blog posts — thoughts on financial markets, technology, and more."
>
  <HeroBanner
    slot="hero"
    title="Blog"
    subheading="All posts"
    type="page"
  />

  <div class="container">
    <div class="row">
      <div class="col-content postlist-container">
        {posts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.slug}
          />
        ))}
      </div>

      <div class="col-sidebar">
        <Sidebar tags={allTags} />
      </div>
    </div>
  </div>
</BaseLayout>
