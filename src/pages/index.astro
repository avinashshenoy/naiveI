---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroBanner from "../components/HeroBanner.astro";
import BlogPostCard from "../components/BlogPostCard.astro";
import Sidebar from "../components/Sidebar.astro";
import { getCollection } from "astro:content";

const allPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const posts = allPosts.slice(0, 3);

const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))];
---

<BaseLayout
  title="Home"
  description="Thoughts, Ideas and Expressions on Financial Markets... From the mind of a Naive Self-Taught Investor"
>
  <HeroBanner
    slot="hero"
    title="Naive Investor"
    subheading="Thoughts, Ideas and Expressions on Financial Markets... From the mind of a Naive Self-Taught Investor"
  />

  <div class="container">
    <div class="row">
      <div class="col-content postlist-container">
        {posts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.slug}
          />
        ))}

        <ul class="pager">
          <li class="next">
            <a href="/blog">All Posts &rarr;</a>
          </li>
        </ul>
      </div>

      <div class="col-sidebar">
        <Sidebar tags={allTags} />
      </div>
    </div>
  </div>
</BaseLayout>
