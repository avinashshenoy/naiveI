---
interface Props {
  title: string;
  subheading?: string;
  backgroundImage?: string;
  type?: "site" | "page" | "post";
  meta?: string;
}

const { title, subheading, backgroundImage = "/images/home-bg.jpg", type = "site", meta } = Astro.props;
---

<header
  class="intro-header"
  style={`background-image: url('${backgroundImage}')`}
>
  <div class="container">
    <div class="row">
      <div style="max-width: 720px; margin: 0 auto; width: 100%; padding: 0 15px;">
        {type === "post" ? (
          <div class="post-heading">
            <h1>{title}</h1>
            {meta && <span class="meta">{meta}</span>}
          </div>
        ) : (
          <div class:list={[type === "site" ? "site-heading" : "page-heading"]}>
            <h1>{title}</h1>
            {subheading && <span class="subheading">{subheading}</span>}
          </div>
        )}
      </div>
    </div>
  </div>
</header>
