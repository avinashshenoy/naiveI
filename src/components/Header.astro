---
interface Props {
  showSearch?: boolean;
}

const { showSearch = true } = Astro.props;
---

<nav class="navbar-custom">
  <a class="navbar-brand" href="/">Naive Investor</a>

  <button class="navbar-toggle" aria-label="Toggle navigation" id="nav-toggle">
    <span class="icon-bar"></span>
    <span class="icon-bar"></span>
    <span class="icon-bar"></span>
  </button>

  <div class="nav-collapse" id="nav-collapse">
    <ul class="nav-list">
      <li><a href="/">Home</a></li>
      <li><a href="/about">About</a></li>
      {showSearch && (
        <li>
          <button class="search-icon" id="search-open" aria-label="Search">
            <i class="fa fa-search"></i>
          </button>
        </li>
      )}
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById("nav-toggle");
  const collapse = document.getElementById("nav-collapse");
  if (toggle && collapse) {
    toggle.addEventListener("click", () => {
      collapse.classList.toggle("open");
    });
    document.addEventListener("click", (e) => {
      if (!toggle.contains(e.target as Node) && !collapse.contains(e.target as Node)) {
        collapse.classList.remove("open");
      }
    });
  }
</script>
